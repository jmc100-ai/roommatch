{
  "name": "roommatch",
  "version": "2.0.0",
  "description": "TravelByVibe — visual hotel search by neighbourhood and room vibe (LiteAPI)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:search-api": "node scripts/test-search-quality.js",
    "test:search-ui": "playwright test tests/search-ui.spec.js",
    "test:search-all": "npm run test:search-api && npm run test:search-ui",
    "baseline:capture": "node scripts/capture-search-baseline.js",
    "baseline:compare": "node scripts/compare-search-baseline.js --capture"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@sentry/node": "^10.52.0",
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "posthog-node": "^5.33.4",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "nodemon": "^3.1.4"
  }
}
