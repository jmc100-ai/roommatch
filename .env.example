# Copy to .env and fill in. Never commit .env.
LITEAPI_PROD_KEY=
LITEAPI_KEY=
GEMINI_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
GEOAPIFY_KEY=
RENDER_EXTERNAL_URL=
INDEX_SECRET=
UNSPLASH_KEY=
SITE_PASSWORD=
# Optional comma/newline list of extra invite codes (merged with config/beta-invite-codes.txt)
SITE_PASSWORDS=
# Beta gate cap (0 or unset = unlimited). SITE_PASSWORD admin code is always exempt.
BETA_MAX_SLOTS=
# 0 = pause new logins; existing rm_gate cookies still work
BETA_GATE_OPEN=1
# Optional message when full or paused (shown on login page)
BETA_GATE_MESSAGE=
VSEARCH_FLAG_MODE=
SOFT_FLAG_COVERAGE_MULT=
SOFT_FLAG_MISS_PENALTY=
SOFT_FLAG_HOTEL_CAP=
