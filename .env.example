# Copy to .env and fill in. Never commit .env.
LITEAPI_PROD_KEY=
LITEAPI_KEY=
GEMINI_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
GEOAPIFY_KEY=
RENDER_EXTERNAL_URL=
INDEX_SECRET=
UNSPLASH_KEY=
SITE_PASSWORD=
# Optional comma/newline list of extra invite codes (merged with config/beta-invite-codes.txt)
SITE_PASSWORDS=
# Max successful logins per invite code (0 or unset = unlimited). E.g. 20 = boop88 works on 20 devices.
# SITE_PASSWORD admin code is always exempt from the cap.
BETA_MAX_SLOTS=
# Master switch: 0 = open site (no login wall); 1 = gate on when SITE_PASSWORD / codes file set
BETA_GATE_ENABLED=1
# 0 = pause new logins; existing rm_gate cookies still work (only when gate enabled)
BETA_GATE_OPEN=1
# Optional message when full or paused (shown on login page)
BETA_GATE_MESSAGE=
VSEARCH_FLAG_MODE=
SOFT_FLAG_COVERAGE_MULT=
SOFT_FLAG_MISS_PENALTY=
SOFT_FLAG_HOTEL_CAP=
